# ─── Network Settings ─────────────────────────────────────────────────────────
# The origin domain allowed by CORS. Must match the frontend location.
ALLOWED_ORIGIN=http://localhost:3000

# ─── GCP Credentials (Server-side Only) ──────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id-here
FITBIT_CLIENT_SECRET=your-fitbit-client-secret-here

# ─── File Paths ───────────────────────────────────────────────────────────────
# Path to credentials.json downloaded from GCP Console (OAuth 2.0 Desktop Client)
CREDENTIALS_PATH=credentials.json

# Path where the OAuth token (including refresh token) will be persisted
TOKEN_PATH=token.json

# ─── User Physiological Baselines ─────────────────────────────────────────────
# Tested maximum heart rate (bpm) — used for VO2 Max calculation
USER_MAX_HR=185.0

# Resting heart rate (bpm) — used for acute stress detection threshold
USER_RESTING_HR=58.0

# Target nightly sleep duration (hours) — used for sleep debt calculation
USER_TARGET_SLEEP_HOURS=8.0

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to true to attempt fetching DAILY_SLEEP_TEMPERATURE_DERIVATIONS.
# If the endpoint returns 404 or empty, a WARNING is logged and sleep_temp = [].
SKIN_TEMP_AVAILABLE=true
